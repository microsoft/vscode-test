{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"rootDir": "src",
		"outDir": "out",
		"lib": [
			"ES2022"
		],
		"types": [
			"node"
		],
		"sourceMap": true,
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules",
		".vscode-test"
	]
}